# Backend
API_KEY=mysecretkey123
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_MB=50
CHROMA_PATH=
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_MAX_CANDIDATES=40
HF_CACHE_DIR=
